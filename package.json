{
  "name": "mynte.studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#core/*": "./app/core/*.js",
    "#inquiry/*": "./app/inquiry/*.js",
    "#providers/*": "./providers/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/eslint-config": "^2.1.2",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^1.4.1",
    "@japa/assert": "^4.1.1",
    "@japa/plugin-adonisjs": "^4.0.0",
    "@japa/runner": "^4.4.0",
    "@julr/tooling-configs": "^4.0.0",
    "@swc/core": "1.13.5",
    "@tuyau/utils": "^0.0.9",
    "@types/node": "^22.15.18",
    "@vitejs/plugin-vue": "^6.0.1",
    "eslint": "^9.36.0",
    "hot-hook": "^0.4.0",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.6.2",
    "ts-node-maintained": "^10.9.6",
    "typescript": "~5.9.3",
    "unocss": "^66.5.2",
    "vite": "^6.3.6"
  },
  "dependencies": {
    "@adonisjs/auth": "^9.5.0",
    "@adonisjs/core": "^6.19.0",
    "@adonisjs/cors": "^2.2.1",
    "@adonisjs/inertia": "^3.1.1",
    "@adonisjs/limiter": "^2.4.0",
    "@adonisjs/lucid": "^21.8.0",
    "@adonisjs/mail": "^9.2.2",
    "@adonisjs/redis": "^9.2.0",
    "@adonisjs/session": "^7.5.1",
    "@adonisjs/shield": "^8.2.0",
    "@adonisjs/static": "^1.1.1",
    "@adonisjs/vite": "^4.0.0",
    "@inertiajs/vue3": "^2.2.4",
    "@tuyau/client": "^0.2.10",
    "@tuyau/core": "^0.4.2",
    "@vinejs/vine": "^3.0.1",
    "@vue/server-renderer": "^3.5.22",
    "edge.js": "^6.3.0",
    "reflect-metadata": "^0.2.2",
    "vue": "^3.5.22"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
